# Configuration du banc FXS — chargée automatiquement par app.py au démarrage.
# Plus besoin de faire `export FXS_GW_URL=...` à la main avant `python3 app.py`.
#
# IP du PC qui fait tourner gateway_server.py (sonnerie/p2p déportés).
# -> METTRE l'IP RÉELLE du PC (ipconfig sur le PC). Réserver une IP fixe au PC.
# Commenter cette ligne pour repasser en Telnet LOCAL (Pi -> gateway directement).
FXS_GW_URL=http://192.168.100.50:5050
